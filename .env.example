# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://wellfilab.com

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_...   # Same as KEY_ID, needed client-side
RAZORPAY_WEBHOOK_SECRET=...                 # dashboard.razorpay.com → Settings → Webhooks

# Plan IDs — create plans at: dashboard.razorpay.com → Products → Subscriptions → Plans
# Diet Plan: ₹149/mo, ₹999/yr
RAZORPAY_PLAN_DIET_MONTHLY=plan_...
RAZORPAY_PLAN_DIET_YEARLY=plan_...

# Finance Plan: ₹149/mo, ₹999/yr
RAZORPAY_PLAN_FINANCE_MONTHLY=plan_...
RAZORPAY_PLAN_FINANCE_YEARLY=plan_...

# Bundle: ₹249/mo, ₹1499/yr
RAZORPAY_PLAN_BUNDLE_MONTHLY=plan_...
RAZORPAY_PLAN_BUNDLE_YEARLY=plan_...

# ── Email (resend.com — free up to 3,000 emails/month) ────────────────────────
RESEND_API_KEY=re_...

# ── Database (supabase.com — Project Settings → Database → Connection string) ──
# POSTGRES_URL: "Transaction" pooled mode, port 6543 — used by the app at runtime (lib/db/client.ts)
# POSTGRES_URL_NON_POOLING: direct connection, port 5432 — used only for migrations (drizzle.config.ts)
POSTGRES_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
POSTGRES_URL_NON_POOLING=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# ── Analytics (add after deploying) ───────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-...
# NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-...
